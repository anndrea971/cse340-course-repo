<%- include('partials/header') %>
<main>
  <h1><%= title %></h1>
  <p>Explore our service project categories:</p>
  <ul>
    <% if (locals.categories && locals.categories.length > 0) { %>
      <% categories.forEach(category => { %>
        <li><%= category.name %></li>
      <% }); %>
    <% } else { %>
      <li>No categories found.</li>
    <% } %>
  </ul>
</main>
<%- include('partials/footer') %>