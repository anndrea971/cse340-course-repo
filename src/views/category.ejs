<%- include('partials/header') %>
<main>
<h1>Category: <%= categoryName %></h1>

<p>Below are the projects associated with this category:</p>

<% if (projects.length > 0) { %>
    <ul class="project-links">
        <% projects.forEach(project => { %>
            <li>
                <a href="/project/<%= project.project_id %>">
                    <%= project.title %>
                </a>
                <span>(Date: <%= project.project_date %>)</span>
            </li>
        <% }) %>
    </ul>
<% } else { %>
    <p>No projects found for this category yet.</p>
<% } %>

<hr style="margin: 2rem 0; border: 0; border-top: 1px solid var(--border-color);">
<a href="/categories">← Back to All Categories</a>
</main>
<%- include('partials/footer') %>