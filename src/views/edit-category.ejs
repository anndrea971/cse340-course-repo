<%- include('partials/header') %>
<main>
  <h1><%= title %></h1>
  <form action="/edit-category/<%= category.category_id %>" method="POST">
    <div class="form-group">
      <label for="name">Category Name</label>
      <input type="text" id="name" name="name" required maxlength="100" value="<%= category.name %>" />
    </div>
    <div class="form-group">
      <label for="description">Description</label>
      <textarea id="description" name="description" maxlength="255"><%= category.description %></textarea>
    </div>
    <button type="submit">Update Category</button>
  </form>
</main>
<%- include('partials/footer') %>
