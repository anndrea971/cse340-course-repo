<%- include('partials/header') %>

<main>
    <h1>Our Partner Organizations</h1>
    
    <% if (organizations.length > 0) { %>
        <ul>
            <% organizations.forEach(org => { %>
                <li>
                    <strong>
                        <a href="/organization/<%= org.organization_id %>">
                            <%= org.name %>
                        </a>
                    </strong>: 
                    <%= org.contact_email %>
                </li>
            <% }) %>
        </ul>
    <% } else { %>
        <p>No organizations found.</p>
    <% } %>
</main>

<%- include('partials/footer') %>