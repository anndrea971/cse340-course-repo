<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    
    <h2>Upcoming Service Projects</h2> 
    <ul>
        <% if (Array.isArray(projects)) { projects.forEach(project => { %>
            <li>
                <strong>
                    <%= new Date(project.project_date).toLocaleDateString(...) %>
                        month: 'long', 
                        day: 'numeric', 
                        year: 'numeric' 
                    }) %>
                </strong>: 
                <%= project.name %> 
                (<%= project.location %>)
            </li>
        <% }); } %>
    </ul>
</main>
<%- include('partials/footer') %>
