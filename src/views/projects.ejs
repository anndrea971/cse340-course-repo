<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    
    <h2>Upcoming Service Projects</h2> 
    <ul>
        <% projects.forEach(project => { %>
            <li>
                <strong>
                    <%= new Date(project.project_date).toLocaleDateString('en-US', { 
                        month: 'long', 
                        day: 'numeric', 
                        year: 'numeric' 
                    }) %>
                </strong>: 
                <%= project.title %> 
                (<%= project.organization_name %>)
            </li>
        <% }); %>
    </ul>
</main>
<%- include('partials/footer') %>