<%- include('partials/header') %>
<main>
  <h1><%= title %></h1>
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Role</th>
      </tr>
    </thead>
    <tbody>
      <% usersList.forEach(u => { %>
        <tr>
          <td><%= u.name %></td>
          <td><%= u.email %></td>
          <td><%= u.role_name %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
  <p><a href="/dashboard">Return to Dashboard</a></p>
</main>
<%- include('partials/footer') %>